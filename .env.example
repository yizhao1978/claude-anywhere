# Telegram (required for Telegram bridge)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# WeChat Work (required for WeChat bridge)
WECOM_BOT_ID=your-bot-id
WECOM_SECRET=your-secret

# QQ Bot (required for QQ bridge)
QQ_APP_ID=
QQ_APP_SECRET=
QQ_WEBHOOK_PORT=9701

# License (optional — leave empty for free tier)
LICENSE_KEY=
LICENSE_SERVER_URL=https://license.claudeanywhere.com

# Claude (optional, auto-detected)
CLAUDE_PATH=
CLAUDE_CWD=

# Knowledge base directories (optional, comma-separated)
# Claude will read these dirs for context — e.g. Obsidian vault, project docs
KNOWLEDGE_DIR=
